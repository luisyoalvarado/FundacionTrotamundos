---
// src/pages/blog/[slug].astro
import Layout from '../../layouts/Layout.astro';
import { client } from '../../lib/sanity';
import { PortableText } from 'astro-portabletext';
import imageUrlBuilder from '@sanity/image-url';

export async function getStaticPaths() {
  const posts = await client.fetch(`*[_type == "post"]{ slug }`);
  return posts.map((post: any) => ({
    params: { slug: post.slug.current },
  }));
}

const { slug } = Astro.params;
const post = await client.fetch(
  `*[_type == "post" && slug.current == $slug][0]{
    title,
    publishedAt,
    mainImage,
    body,
    excerpt,
    "authorName": author->name,
    "categories": categories[]->title
  }`,
  { slug }
);

const builder = imageUrlBuilder(client);
function urlFor(source: any) {
  return builder.image(source);
}

const formattedDate = post.publishedAt 
  ? new Date(post.publishedAt).toLocaleDateString('es-ES', { year: 'numeric', month: 'long', day: 'numeric' })
  : '';

const ogImage = post.mainImage ? urlFor(post.mainImage).width(1200).height(630).url() : undefined;
---

<Layout title={post.title} description={post.excerpt} image={ogImage}>
    <!-- Contenedor principal optimizado para lectura web y móvil -->
    <main style="max-width: 800px; margin: 0 auto; padding: 40px 5% 80px;">
        
        <article>
            <!-- Navegación de regreso -->
            <a href="/blog" style="color: #666; text-decoration: none; font-size: 0.95rem; font-weight: 600; display: inline-flex; align-items: center; gap: 8px; margin-bottom: 2rem; transition: color 0.2s;" onmouseover="this.style.color='var(--color-primary)'" onmouseout="this.style.color='#666'">
                <i class="fas fa-arrow-left"></i> Volver al Blog
            </a>

            <!-- ENCABEZADO DEL ARTÍCULO -->
            <header style="margin-bottom: 2.5rem;">
                
                <!-- Categorías -->
                {post.categories && post.categories.length > 0 && (
                    <div style="margin-bottom: 15px;">
                        {post.categories.map((category: string) => (
                            <span style="display: inline-block; background: rgba(45, 90, 39, 0.1); color: var(--color-primary); font-size: 0.75rem; font-weight: 700; text-transform: uppercase; padding: 4px 10px; border-radius: 4px; margin-right: 8px; letter-spacing: 0.5px;">
                                {category}
                            </span>
                        ))}
                    </div>
                )}
                
                <h1 style="font-size: clamp(2rem, 4vw, 3rem); color: var(--color-dark); margin-bottom: 1rem; line-height: 1.2;">
                    {post.title}
                </h1>

                <!-- Metadatos: Autor y Fecha -->
                <div style="display: flex; align-items: center; gap: 15px; color: #666; font-size: 0.95rem; border-bottom: 1px solid var(--border-subtle); padding-bottom: 1.5rem;">
                    {post.authorName && (
                        <span><i class="fas fa-pen-nib" style="margin-right: 5px; color: var(--color-accent);"></i> {post.authorName}</span>
                    )}
                    <span><i class="far fa-calendar-alt" style="margin-right: 5px; color: var(--color-accent);"></i> {formattedDate}</span>
                </div>
            </header>

            <!-- IMAGEN PRINCIPAL (RESIZED & OPTIMIZADA) -->
            {post.mainImage && (
                <figure style="margin: 0 0 3rem 0; border-radius: var(--radius-md); overflow: hidden;">
                    <img 
                        src={urlFor(post.mainImage).width(800).height(450).url()} 
                        alt={post.title} 
                        style="width: 100%; max-height: 450px; object-fit: cover; display: block; background-color: #f4f4f4;"
                    />
                </figure>
            )}

            <!-- CUERPO DEL ARTÍCULO (PORTABLE TEXT) -->
            <div class="prose-content" style="font-family: 'Inter', sans-serif; line-height: 1.8; color: #333; font-size: 1.1rem;">
                {post.body ? (
                    <PortableText value={post.body} />
                ) : (
                    <p style="font-style: italic; color: #888;">El contenido de este artículo no está disponible.</p>
                )}
            </div>

        </article>
    </main>
</Layout>

<!-- ESTILOS GLOBALES PARA EL TEXTO DEL BLOG -->
<style is:global>
    /* Estilos tipográficos limpios y editoriales para el contenido inyectado por Sanity */
    .prose-content p { 
        margin-bottom: 1.5rem; 
    }
    .prose-content h2 { 
        font-size: 1.8rem; 
        color: var(--color-dark); 
        margin-top: 2.5rem; 
        margin-bottom: 1rem; 
        line-height: 1.3;
    }
    .prose-content h3 { 
        font-size: 1.4rem; 
        color: var(--color-dark); 
        margin-top: 2rem; 
        margin-bottom: 1rem; 
    }
    .prose-content ul, .prose-content ol { 
        margin-bottom: 1.5rem; 
        padding-left: 1.5rem; 
    }
    .prose-content li { 
        margin-bottom: 0.5rem; 
    }
    .prose-content a {
        color: var(--color-primary);
        text-decoration: none;
        border-bottom: 1px solid transparent;
        transition: border-bottom 0.2s;
    }
    .prose-content a:hover {
        border-bottom: 1px solid var(--color-primary);
    }
    .prose-content strong { 
        color: var(--color-dark); 
    }
    .prose-content blockquote {
        border-left: 4px solid var(--color-accent);
        margin: 2rem 0;
        padding: 1rem 1.5rem;
        font-style: italic;
        color: #555;
        background-color: rgba(230, 126, 34, 0.05);
        border-radius: 0 8px 8px 0;
    }
    .prose-content img {
        border-radius: 8px;
        margin: 2rem 0;
        max-height: 500px;
        width: auto;
        max-width: 100%;
        display: block;
    }
</style>