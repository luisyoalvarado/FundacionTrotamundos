---
// src/pages/tienda.astro
import Layout from '../layouts/Layout.astro';

// SERVER-SIDE FRONTMATTER
// Define SEO metadata for the store
const pageTitle = "Tienda Oficial";
const pageDescription = "Adquiere el libro 'Lo que guardo en mi maleta' y apoya la misión de El Trotamundos. Cada compra transforma la vida de niños a través del arte y la educación.";
const siteUrl = "https://fundaciontrotamundos.org/tienda";
const ogImage = "https://fundaciontrotamundos.org/assets/img/libro-lo-que-guardo-en-mi-maleta-el-trotamundos.jpg";

// GEO SCHEMA MARKUP
// Product & Offer data for AI and Search Engines
const schemaMarkup = JSON.stringify({
  "@context": "https://schema.org",
  "@type": "Product",
  "name": "Libro: Lo que guardo en mi maleta",
  "image": ogImage,
  "description": pageDescription,
  "brand": {
    "@type": "Organization",
    "name": "Fundación Trotamundos"
  },
  "offers": {
    "@type": "Offer",
    "url": siteUrl,
    "priceCurrency": "USD",
    "price": "29.00",
    "availability": "https://schema.org/InStock",
    "seller": {
      "@type": "Organization",
      "name": "Fundación Trotamundos"
    }
  }
});
---

<Layout title={pageTitle} description={pageDescription} image={ogImage}>
    
    <!-- GEO STRUCTURED DATA INJECTION -->
    <script type="application/ld+json" set:html={schemaMarkup}></script>

    <!-- ROLLBACK: Utilizamos tu HTML original para no romper los estilos globales del banner -->
    <section class="internal-hero tienda-bg">
        <h1>Tienda <span class="highlight">Oficial</span></h1>
        <p>Conoce la historia detrás de la misión. Tu lectura construye el futuro de un niño.</p>
    </section>

    <!-- PRODUCT CATALOG -->
    <!-- Contenedor ajustado con max-width para compactar la información y centrar la vista -->
    <main class="modern-store-container" style="max-width: 950px; margin: 4rem auto; padding: 0 1.5rem;">
        <div class="store-catalog">
            
            <!-- GRID ACTUALIZADO: 1fr 1fr asegura que la imagen sea grande y tome la mitad de la tarjeta -->
            <article class="product-card-unified" style="display: grid; grid-template-columns: repeat(auto-fit, minmax(350px, 1fr)); gap: 4rem; align-items: center; background: #fff; padding: 2.5rem; border-radius: 12px; box-shadow: 0 10px 30px rgba(0,0,0,0.06);">
                
                <!-- PRODUCT IMAGE AREA -->
                <div class="product-visual">
                    <div class="product-book-image">
                        <img src="/assets/img/libro-lo-que-guardo-en-mi-maleta-el-trotamundos.jpg" alt="Portada del libro: Lo que guardo en mi maleta" style="width: 100%; max-width: 450px; display: block; margin: 0 auto; border-radius: 8px; box-shadow: 0 15px 30px rgba(0,0,0,0.12);">
                    </div>
                </div>

                <!-- PRODUCT DETAILS & CHECKOUT AREA -->
                <div class="product-info">
                    <h2 style="font-size: 2.2rem; margin-bottom: 1rem; color: #222;">Lo que guardo en mi maleta</h2>
                    
                    <p style="margin-bottom: 1rem; color: #555; line-height: 1.6; font-size: 1.05rem;">Una colección de anécdotas e imágenes que recoge experiencias transformadoras vividas por El Trotamundos en su gesta humanitaria y de servicio por veintiocho países alrededor del mundo.</p>
                    <p style="margin-bottom: 1.5rem; color: #555; line-height: 1.6; font-size: 1.05rem;">Al leerlo, sentirás que eres parte de cada instante vivido por este personaje en su misión de transformar el mundo un niño a la vez.</p>

                    <!-- CAJITA DE FEATURES ARREGLADA -->
                    <!-- Se le dio un fondo gris claro (background: #f8f9fa), padding para que respire, y un gap de 15px para separar el icono del texto -->
                    <ul class="product-feature-list" style="list-style: none; padding: 1.5rem; margin-bottom: 2rem; background: #f8f9fa; border-radius: 10px; border: 1px solid #eaeaea;">
                        <li style="margin-bottom: 1.2rem; display: flex; align-items: center; gap: 15px;">
                            <i class="fas fa-check-circle" style="color: #4facfe; font-size: 1.25rem; min-width: 20px;"></i> 
                            <span style="font-size: 1rem; color: #444;">Memorias de 28 países recorridos.</span>
                        </li>
                        <li style="margin-bottom: 1.2rem; display: flex; align-items: center; gap: 15px;">
                            <i class="fas fa-check-circle" style="color: #4facfe; font-size: 1.25rem; min-width: 20px;"></i> 
                            <span style="font-size: 1rem; color: #444;">Fotografías exclusivas de la fundación.</span>
                        </li>
                        <li style="display: flex; align-items: center; gap: 15px;">
                            <i class="fas fa-heart" style="color: #ff6b6b; font-size: 1.25rem; min-width: 20px;"></i> 
                            <span style="font-size: 1rem; color: #444;"><strong><span class="animate-counter" data-target="100">0</span>% de las ganancias</strong> apoyan nuestros proyectos.</span>
                        </li>
                    </ul>

                    <!-- STRIPE CHECKOUT INTEGRATION -->
                    <div class="checkout-box" style="padding-top: 0.5rem; border: none;">
                        <a href="https://buy.stripe.com/5kQaEXd3Mc1i1DO64t2kw00" class="btn-buy-modern" style="display: flex; align-items: center; justify-content: space-between; padding: 1.2rem 2rem; background: #222; color: #fff; border-radius: 8px; text-decoration: none; font-size: 1.1rem; transition: transform 0.2s ease;">
                            <span><i class="fas fa-shopping-basket" style="margin-right: 10px;"></i> Comprar Libro</span>
                            <span style="border-left: 1px solid rgba(255,255,255,0.3); padding-left: 15px; font-weight: 800;">$29.00</span>
                        </a>
                        
                        <!-- TEXTO GENÉRICO DE ENVÍO -->
                        <p class="shipping-note-modern" style="margin-top: 1.2rem; color: #666; font-size: 0.95rem; text-align: center; display: flex; align-items: center; justify-content: center; gap: 8px;">
                            <i class="fas fa-truck-fast" style="color: #4facfe;"></i> Envíos disponibles a Puerto Rico y Estados Unidos.
                        </p>
                    </div>
                </div>

            </article>
        </div>
    </main>
</Layout>

<!-- CLIENT-SIDE SCRIPTS -->
<script>
    // Motor de animación sutil solo aplicado al porcentaje de ganancias
    document.addEventListener("DOMContentLoaded", () => {
        const counters = document.querySelectorAll('.animate-counter');
        
        const observer = new IntersectionObserver((entries) => {
            entries.forEach(entry => {
                if (entry.isIntersecting) {
                    const counter = entry.target as HTMLElement;
                    const target = +counter.getAttribute('data-target')!;
                    let count = 0;
                    
                    const updateCount = () => {
                        const inc = target / 20; // Velocidad de la animación
                        if (count < target) {
                            count += inc;
                            counter.innerText = Math.ceil(count).toString();
                            setTimeout(updateCount, 30);
                        } else {
                            counter.innerText = target.toString();
                        }
                    };
                    updateCount();
                    observer.disconnect();
                }
            });
        }, { threshold: 0.5 });

        counters.forEach(counter => observer.observe(counter));
    });
</script>