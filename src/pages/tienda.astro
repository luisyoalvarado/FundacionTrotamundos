---
// src/pages/tienda.astro

// IMPORT LAYOUT
// Ensure the path to your layout file is correct based on your project structure
import Layout from '../layouts/Layout.astro';

// SEO & METADATA CONFIGURATION
// Define specific metadata for the store page to ensure good social sharing
const pageTitle = "Tienda Oficial | Fundación Trotamundos";
const pageDescription = "Adquiere el libro 'Lo que guardo en mi maleta' y apoya la misión de El Trotamundos. Cada compra transforma vidas.";
const siteUrl = "https://fundaciontrotamundos.org/tienda";
const ogImage = "https://fundaciontrotamundos.org/assets/img/libro-lo-que-guardo-en-mi-maleta-el-trotamundos.jpg";

// GEO SCHEMA MARKUP (JSON-LD)
// Product & Offer data injected for AI search engines and rich snippets
const schemaMarkup = JSON.stringify({
  "@context": "https://schema.org",
  "@type": "Product",
  "name": "Libro: Lo que guardo en mi maleta",
  "image": ogImage,
  "description": pageDescription,
  "brand": {
    "@type": "Organization",
    "name": "Fundación Trotamundos"
  },
  "offers": {
    "@type": "Offer",
    "url": siteUrl,
    "priceCurrency": "USD",
    "price": "29.00",
    "availability": "https://schema.org/InStock",
    "seller": {
      "@type": "Organization",
      "name": "Fundación Trotamundos"
    }
  }
});
---

<Layout title={pageTitle} description={pageDescription} image={ogImage}>
    
    <!-- STRUCTURED DATA INJECTION -->
    <!-- Adds the JSON-LD schema to the head of the document for SEO/GEO -->
    <script type="application/ld+json" set:html={schemaMarkup}></script>

    <!-- PAGE HERO SECTION -->
    <!-- Retaining original classes to inherit your global style.css layout -->
    <section class="internal-hero tienda-bg">
        <h1>Tienda <span class="highlight">Oficial</span></h1>
        <p>Tu lectura construye el futuro de un niño.</p>
    </section>

    <!-- COMPACT E-COMMERCE CONTAINER -->
    <main class="simple-store-container">
        
        <!-- STANDARD COMPACT PRODUCT CARD -->
        <article class="compact-product-card">
            
            <!-- PRODUCT IMAGE HEADER -->
            <div class="card-image-header">
                <img 
                    src="/assets/img/libro-lo-que-guardo-en-mi-maleta-el-trotamundos.jpg" 
                    alt="Portada del libro: Lo que guardo en mi maleta" 
                    loading="lazy"
                />
            </div>

            <!-- PRODUCT ESSENTIAL INFO -->
            <div class="card-body">
                <span class="category-badge">Libro Oficial</span>
                <h2 class="product-title">Lo que guardo en mi maleta</h2>
                <div class="price-tag">$29.00</div>

                <!-- SIMPLIFIED IMPACT BADGE WITH ANIMATION -->
                <div class="impact-badge">
                    <i class="fas fa-heart"></i>
                    <span><strong><span class="animate-counter" data-target="100">0</span>% de las ganancias</strong> donadas</span>
                </div>

                <!-- DIRECT STRIPE CHECKOUT -->
                <a href="https://buy.stripe.com/5kQaEXd3Mc1i1DO64t2kw00" class="btn-stripe-checkout">
                    <span>Comprar ahora</span>
                    <i class="fas fa-arrow-right"></i>
                </a>
                
                <!-- NEW SHIPPING INCLUDED NOTE -->
                <p class="shipping-included-note">
                    <i class="fas fa-box-open"></i> 
                    Manejo y envío a 🇵🇷 y 🇺🇸 incluido en el monto total.
                </p>
            </div>
        </article>

    </main>
</Layout>

<!-- SCOPED COMPONENT STYLES -->
<!-- Minimalist, modern e-commerce styling optimized for conversion -->
<style>
    /* CONTAINER CENTERING */
    .simple-store-container {
        display: flex;
        justify-content: center;
        align-items: center;
        padding: 5rem 1.5rem;
        background-color: #fafafa; /* Soft background to make the card pop */
    }

    /* COMPACT CARD STYLING */
    .compact-product-card {
        background: #ffffff;
        width: 100%;
        max-width: 360px; /* Standard online store item width */
        border-radius: 16px;
        overflow: hidden;
        box-shadow: 0 8px 24px rgba(0, 0, 0, 0.06);
        border: 1px solid rgba(0, 0, 0, 0.04);
        transition: transform 0.3s ease, box-shadow 0.3s ease;
    }

    .compact-product-card:hover {
        transform: translateY(-5px);
        box-shadow: 0 15px 35px rgba(0, 0, 0, 0.1);
    }

    /* IMAGE AREA */
    .card-image-header {
        width: 100%;
        background: #f0f0f0;
        padding: 2rem;
        display: flex;
        justify-content: center;
        align-items: center;
    }

    .card-image-header img {
        width: 180px; /* Smaller, standard book render */
        height: auto;
        border-radius: 4px;
        box-shadow: 0 10px 20px rgba(0, 0, 0, 0.15);
        transition: transform 0.4s ease;
    }

    .compact-product-card:hover .card-image-header img {
        transform: scale(1.05);
    }

    /* CARD CONTENT AREA */
    .card-body {
        padding: 2rem 1.5rem;
        text-align: center;
        display: flex;
        flex-direction: column;
        align-items: center;
    }

    .category-badge {
        font-size: 0.75rem;
        text-transform: uppercase;
        letter-spacing: 1px;
        font-weight: 700;
        color: #666;
        margin-bottom: 0.5rem;
    }

    .product-title {
        font-size: 1.4rem;
        font-weight: 800;
        color: #1a1a1a;
        margin-bottom: 0.5rem;
        line-height: 1.3;
    }

    .price-tag {
        font-size: 1.6rem;
        font-weight: 800;
        color: #222;
        margin-bottom: 1.5rem;
    }

    /* IMPACT HIGHLIGHT */
    .impact-badge {
        display: flex;
        align-items: center;
        gap: 8px;
        background: #fff0f0;
        color: #d93838;
        padding: 0.5rem 1rem;
        border-radius: 50px;
        font-size: 0.85rem;
        margin-bottom: 2rem;
    }

    /* STRIPE CHECKOUT BUTTON */
    .btn-stripe-checkout {
        display: flex;
        align-items: center;
        justify-content: center;
        gap: 10px;
        width: 100%;
        padding: 1rem;
        background: #1a1a1a;
        color: #ffffff;
        border-radius: 8px;
        text-decoration: none;
        font-size: 1.05rem;
        font-weight: 600;
        transition: background 0.2s ease, transform 0.2s ease;
    }

    .btn-stripe-checkout:hover {
        background: #000000;
        transform: translateY(-2px);
    }

    /* SHIPPING TEXT */
    .shipping-included-note {
        margin-top: 1rem;
        color: #777;
        font-size: 0.8rem;
        line-height: 1.4;
        display: flex;
        align-items: flex-start;
        justify-content: center;
        gap: 6px;
    }

    .shipping-included-note i {
        margin-top: 3px;
        color: #4facfe;
    }
</style>

<!-- CLIENT-SIDE JAVASCRIPT -->
<!-- Handles dynamic interactions that run on the user's browser -->
<script>
    // Intersection Observer for animated number counters
    // Triggers the count-up animation when the element scrolls into view
    document.addEventListener("DOMContentLoaded", () => {
        const counters = document.querySelectorAll('.animate-counter');
        
        const observer = new IntersectionObserver((entries) => {
            entries.forEach(entry => {
                if (entry.isIntersecting) {
                    const counter = entry.target as HTMLElement;
                    const target = +counter.getAttribute('data-target')!;
                    let count = 0;
                    
                    // Recursive function to animate the number smoothly
                    const updateCount = () => {
                        const inc = target / 20; // Controls the speed of the counter
                        if (count < target) {
                            count += inc;
                            counter.innerText = Math.ceil(count).toString();
                            setTimeout(updateCount, 30);
                        } else {
                            counter.innerText = target.toString();
                        }
                    };
                    updateCount();
                    
                    // Stop observing once the animation completes
                    observer.unobserve(counter);
                }
            });
        }, { threshold: 0.5 }); // Triggers when 50% of the element is visible

        counters.forEach(counter => observer.observe(counter));
    });
</script>