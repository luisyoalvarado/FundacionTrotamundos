---
// src/pages/tienda.astro

// IMPORT LAYOUT
// Ensure the path to your layout file is correct based on your project structure
import Layout from '../layouts/Layout.astro';

// SEO & METADATA CONFIGURATION
// Define specific metadata for the store page to ensure good social sharing
const pageTitle = "Tienda Oficial | Fundación Trotamundos";
const pageDescription = "Adquiere el libro 'Lo que guardo en mi maleta' y apoya la misión de El Trotamundos. Cada compra transforma vidas.";
const siteUrl = "https://fundaciontrotamundos.org/tienda";
const ogImage = "https://fundaciontrotamundos.org/assets/img/libro-lo-que-guardo-en-mi-maleta-el-trotamundos.jpg";

// GEO SCHEMA MARKUP (JSON-LD)
// Product & Offer data injected for AI search engines and rich snippets
const schemaMarkup = JSON.stringify({
  "@context": "https://schema.org",
  "@type": "Product",
  "name": "Libro: Lo que guardo en mi maleta",
  "image": ogImage,
  "description": pageDescription,
  "brand": {
    "@type": "Organization",
    "name": "Fundación Trotamundos"
  },
  "offers": {
    "@type": "Offer",
    "url": siteUrl,
    "priceCurrency": "USD",
    "price": "29.00",
    "availability": "https://schema.org/InStock",
    "seller": {
      "@type": "Organization",
      "name": "Fundación Trotamundos"
    }
  }
});
---

<Layout title={pageTitle} description={pageDescription} image={ogImage}>
    
    <!-- STRUCTURED DATA INJECTION -->
    <!-- Adds the JSON-LD schema to the head of the document for SEO/GEO -->
    <script type="application/ld+json" set:html={schemaMarkup}></script>

    <!-- PAGE HERO SECTION -->
    <!-- Retaining original classes to inherit your global style.css layout -->
    <section class="internal-hero tienda-bg">
        <h1>Tienda <span class="highlight">Oficial</span></h1>
        <p>Tu lectura construye el futuro de un niño.</p>
    </section>

    <!-- E-COMMERCE GRID CONTAINER -->
    <!-- Designed to hold multiple items in the future (2 per row on desktop) -->
    <main class="store-grid-container">
        
        <div class="product-grid">
            <!-- HORIZONTAL PRODUCT CARD -->
            <article class="product-card-horizontal">
                
                <!-- PRODUCT IMAGE (LEFT SIDE) -->
                <div class="card-image-box">
                    <img 
                        src="/assets/img/libro-lo-que-guardo-en-mi-maleta-el-trotamundos.jpg" 
                        alt="Portada del libro: Lo que guardo en mi maleta" 
                        loading="lazy"
                    />
                </div>

                <!-- PRODUCT INFO (RIGHT SIDE) -->
                <div class="card-content-box">
                    <h2 class="product-title">Libro: Lo que guardo en mi maleta</h2>
                    
                    <p class="short-description">
                        Descubre una colección inspiradora de anécdotas y fotografías que documentan la misión transformadora de El Trotamundos a través de 28 países.
                    </p>

                    <div class="price-row">
                        <span class="price-tag">$29.00</span>
                    </div>

                    <!-- IMPACT HIGHLIGHT WITH ANIMATED COUNTER -->
                    <div class="philanthropy-notice">
                        <i class="fas fa-heart"></i>
                        <span>El <strong><span class="animate-counter" data-target="100">0</span>%</strong> de las ganancias son donadas a nuestros programas de filantropía.</span>
                    </div>

                    <!-- DIRECT STRIPE CHECKOUT -->
                    <a href="https://buy.stripe.com/5kQaEXd3Mc1i1DO64t2kw00" class="btn-primary-buy">
                        <span>Comprar ahora</span>
                        <i class="fas fa-shopping-bag"></i>
                    </a>
                    
                    <!-- SHIPPING INFO -->
                    <p class="shipping-info">
                        <i class="fas fa-box-open"></i> 
                        Manejo y envío a 🇵🇷 y 🇺🇸 incluido en el precio.
                    </p>
                </div>
            </article>
            
            <!-- Future products can be added here and will automatically align next to the first one on desktop -->
        </div>

    </main>
</Layout>

<!-- SCOPED COMPONENT STYLES -->
<!-- Responsive, minimalist, and dynamic styling for horizontal cards -->
<style>
    /* MAIN CONTAINER & GRID SYSTEM */
    .store-grid-container {
        max-width: 1200px;
        margin: 0 auto;
        padding: 5rem 1.5rem;
        background-color: #fafafa;
    }

    /* GRID LAYOUT: 2 columns on desktop, 1 on mobile */
    .product-grid {
        display: grid;
        grid-template-columns: repeat(auto-fill, minmax(480px, 1fr));
        gap: 2.5rem;
    }

    /* HORIZONTAL CARD STYLING */
    .product-card-horizontal {
        display: flex;
        flex-direction: row;
        background: #ffffff;
        border-radius: 12px;
        overflow: hidden;
        box-shadow: 0 4px 15px rgba(0, 0, 0, 0.05);
        border: 1px solid rgba(0, 0, 0, 0.04);
        transition: transform 0.3s ease, box-shadow 0.3s ease;
    }

    .product-card-horizontal:hover {
        transform: translateY(-4px);
        box-shadow: 0 12px 30px rgba(0, 0, 0, 0.08);
    }

    /* IMAGE CONTAINER (Fills the space entirely) */
    .card-image-box {
        flex: 0 0 40%; /* Takes up 40% of the card width */
        background: #f4f4f4;
        position: relative;
        overflow: hidden;
    }

    .card-image-box img {
        width: 100%;
        height: 100%;
        object-fit: cover; /* Ensures the square image covers the area perfectly */
        display: block;
        transition: transform 0.5s ease;
    }

    .product-card-horizontal:hover .card-image-box img {
        transform: scale(1.05);
    }

    /* CONTENT CONTAINER */
    .card-content-box {
        flex: 1; /* Takes up the remaining 60% */
        padding: 2rem;
        display: flex;
        flex-direction: column;
        justify-content: center;
    }

    .product-title {
        font-size: 1.35rem;
        font-weight: 800;
        color: #1a1a1a;
        margin-bottom: 0.8rem;
        line-height: 1.2;
    }

    .short-description {
        font-size: 0.95rem;
        color: #555;
        line-height: 1.5;
        margin-bottom: 1.2rem;
    }

    .price-row {
        margin-bottom: 1.2rem;
    }

    .price-tag {
        font-size: 1.5rem;
        font-weight: 800;
        color: #1a1a1a;
    }

    /* PHILANTHROPY NOTICE */
    .philanthropy-notice {
        display: flex;
        align-items: flex-start;
        gap: 10px;
        background: #f8f9fa;
        padding: 0.8rem 1rem;
        border-radius: 8px;
        border-left: 3px solid #ff6b6b;
        font-size: 0.85rem;
        color: #444;
        margin-bottom: 1.5rem;
        line-height: 1.4;
    }

    .philanthropy-notice i {
        color: #ff6b6b;
        margin-top: 3px;
    }

    /* BUY BUTTON */
    .btn-primary-buy {
        display: flex;
        align-items: center;
        justify-content: center;
        gap: 10px;
        width: 100%;
        padding: 1rem;
        background: #1a1a1a;
        color: #ffffff;
        border-radius: 8px;
        text-decoration: none;
        font-size: 1.05rem;
        font-weight: 600;
        transition: background 0.2s ease, transform 0.2s ease;
    }

    .btn-primary-buy:hover {
        background: #000000;
        transform: translateY(-2px);
    }

    /* SHIPPING INFO */
    .shipping-info {
        margin-top: 1rem;
        color: #777;
        font-size: 0.8rem;
        text-align: center;
        display: flex;
        align-items: center;
        justify-content: center;
        gap: 6px;
    }

    .shipping-info i {
        color: #4facfe;
    }

    /* MOBILE RESPONSIVE DESIGN */
    /* Transforms the horizontal card into a standard vertical card on smaller screens */
    @media (max-width: 768px) {
        .product-grid {
            grid-template-columns: 1fr; /* 1 column on mobile */
        }

        .product-card-horizontal {
            flex-direction: column; /* Stacks image on top of text */
        }

        .card-image-box {
            flex: auto;
            width: 100%;
            aspect-ratio: 1 / 1; /* Maintains the square shape of the image on mobile */
        }

        .card-content-box {
            padding: 1.5rem;
        }

        .product-title {
            font-size: 1.5rem;
        }
    }
</style>

<!-- CLIENT-SIDE JAVASCRIPT -->
<!-- Handles dynamic interactions that run on the user's browser -->
<script>
    // Intersection Observer for animated number counters
    // Triggers the count-up animation when the element scrolls into view
    document.addEventListener("DOMContentLoaded", () => {
        const counters = document.querySelectorAll('.animate-counter');
        
        const observer = new IntersectionObserver((entries) => {
            entries.forEach(entry => {
                if (entry.isIntersecting) {
                    const counter = entry.target as HTMLElement;
                    const target = +counter.getAttribute('data-target')!;
                    let count = 0;
                    
                    // Recursive function to animate the number smoothly
                    const updateCount = () => {
                        const inc = target / 20; // Controls the speed of the counter
                        if (count < target) {
                            count += inc;
                            counter.innerText = Math.ceil(count).toString();
                            setTimeout(updateCount, 30);
                        } else {
                            counter.innerText = target.toString();
                        }
                    };
                    updateCount();
                    
                    // Stop observing once the animation completes
                    observer.unobserve(counter);
                }
            });
        }, { threshold: 0.5 }); // Triggers when 50% of the element is visible

        counters.forEach(counter => observer.observe(counter));
    });
</script>