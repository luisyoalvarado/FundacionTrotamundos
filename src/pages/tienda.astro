---
// src/pages/tienda.astro

// IMPORT LAYOUT
import Layout from '../layouts/Layout.astro';

// SEO & METADATA CONFIGURATION
const pageTitle = "Tienda Oficial | Fundación Trotamundos";
const pageDescription = "Adquiere el libro 'Lo que guardo en mi maleta' y apoya la misión de El Trotamundos. Cada compra transforma vidas.";
const siteUrl = "https://fundaciontrotamundos.org/tienda";
const ogImage = "https://fundaciontrotamundos.org/assets/img/libro-lo-que-guardo-en-mi-maleta-el-trotamundos.jpg";

// GEO SCHEMA MARKUP (JSON-LD)
const schemaMarkup = JSON.stringify({
  "@context": "https://schema.org",
  "@type": "Product",
  "name": "Libro: Lo que guardo en mi maleta",
  "image": ogImage,
  "description": pageDescription,
  "brand": {
    "@type": "Organization",
    "name": "Fundación Trotamundos"
  },
  "offers": {
    "@type": "Offer",
    "url": siteUrl,
    "priceCurrency": "USD",
    "price": "29.00",
    "availability": "https://schema.org/InStock",
    "seller": {
      "@type": "Organization",
      "name": "Fundación Trotamundos"
    }
  }
});
---

<Layout title={pageTitle} description={pageDescription} image={ogImage}>
    
    <!-- STRUCTURED DATA INJECTION -->
    <script type="application/ld+json" set:html={schemaMarkup}></script>

    <!-- PAGE HERO SECTION -->
    <section class="internal-hero tienda-bg">
        <h1>Tienda <span class="highlight">Oficial</span></h1>
        <p>Tu lectura construye el futuro de un niño.</p>
    </section>

    <!-- E-COMMERCE CATALOG CONTAINER -->
    <!-- Max-width is restricted so the 2-column layout looks appropriately sized, not stretched -->
    <main class="store-catalog-container">
        
        <!-- PRODUCT GRID (2 columns on desktop, 1 on mobile) -->
        <div class="ecommerce-grid">
            
            <!-- STANDARD VERTICAL PRODUCT CARD -->
            <article class="standard-product-card">
                
                <!-- SQUARE IMAGE CONTAINER -->
                <!-- Ensures image is always fully visible without cropping -->
                <div class="product-image-square">
                    <img 
                        src="/assets/img/libro-lo-que-guardo-en-mi-maleta-el-trotamundos.jpg" 
                        alt="Libro: Lo que guardo en mi maleta" 
                        loading="lazy"
                    />
                </div>

                <!-- COMPACT PRODUCT DETAILS -->
                <div class="product-details">
                    <h2 class="product-title">Libro: Lo que guardo en mi maleta</h2>
                    
                    <p class="product-short-desc">
                        Descubre anécdotas y fotografías que documentan la misión de El Trotamundos a través de 28 países.
                    </p>

                    <div class="product-price">$29.00</div>

                    <div class="philanthropy-text">
                        Todas las ganancias (<span class="animate-counter" data-target="100">0</span>%) son donadas a nuestros programas de filantropía.
                    </div>

                    <a href="https://buy.stripe.com/5kQaEXd3Mc1i1DO64t2kw00" class="btn-buy-simple">
                        Comprar
                    </a>
                    
                    <!-- MINIMAL SHIPPING TEXT -->
                    <p class="shipping-text">
                        Manejo y envío a 🇵🇷 y 🇺🇸 incluido en el precio.
                    </p>
                </div>
            </article>

            <!-- Example of a second empty card to visualize the 2-column layout. -->
            <!-- You can delete this or replace it with future products -->
            <!-- 
            <article class="standard-product-card" style="opacity: 0.5; pointer-events: none;">
                <div class="product-image-square" style="background: #eee;"></div>
                <div class="product-details">
                    <h2 class="product-title">Próximo Producto</h2>
                    <p class="product-short-desc">Próximamente disponible en nuestra tienda oficial.</p>
                </div>
            </article>
            -->
            
        </div>
    </main>
</Layout>

<!-- SCOPED COMPONENT STYLES -->
<style>
    /* CATALOG CONTAINER */
    .store-catalog-container {
        max-width: 800px; /* Restricts width so the 2 columns look proportional */
        margin: 0 auto;
        padding: 4rem 1.5rem;
    }

    /* 2-COLUMN GRID SYSTEM */
    .ecommerce-grid {
        display: grid;
        grid-template-columns: repeat(2, 1fr); /* Exactly 2 columns as requested */
        gap: 2rem;
    }

    /* STANDARD VERTICAL CARD */
    .standard-product-card {
        background: #ffffff;
        border-radius: 8px;
        overflow: hidden;
        border: 1px solid #eaeaea;
        transition: transform 0.3s ease, box-shadow 0.3s ease;
        display: flex;
        flex-direction: column;
    }

    /* Interactive hover effect */
    .standard-product-card:hover {
        transform: translateY(-4px);
        box-shadow: 0 10px 25px rgba(0, 0, 0, 0.08);
    }

    /* STRICT SQUARE IMAGE CONTAINER */
    .product-image-square {
        width: 100%;
        aspect-ratio: 1 / 1; /* Forces a perfect square */
        background-color: #fcfcfc;
        padding: 1.5rem; /* Padding so the book doesn't touch the edges */
        display: flex;
        align-items: center;
        justify-content: center;
        border-bottom: 1px solid #f0f0f0;
    }

    .product-image-square img {
        width: 100%;
        height: 100%;
        object-fit: contain; /* CRITICAL: Resizes the image to fit entirely inside the square */
        transition: transform 0.4s ease;
    }

    /* Subtle image zoom on hover */
    .standard-product-card:hover .product-image-square img {
        transform: scale(1.04);
    }

    /* COMPACT TYPOGRAPHY & LAYOUT */
    .product-details {
        padding: 1.5rem;
        display: flex;
        flex-direction: column;
        flex-grow: 1; /* Pushes button to bottom if descriptions vary in length */
    }

    .product-title {
        font-size: 1.1rem;
        font-weight: 700;
        color: #111;
        margin-bottom: 0.5rem;
        line-height: 1.3;
    }

    .product-short-desc {
        font-size: 0.85rem;
        color: #666;
        line-height: 1.5;
        margin-bottom: 1rem;
    }

    .product-price {
        font-size: 1.25rem;
        font-weight: 800;
        color: #000;
        margin-bottom: 1rem;
    }

    .philanthropy-text {
        font-size: 0.8rem;
        color: #444;
        background: #fdf5f5;
        padding: 0.6rem;
        border-radius: 6px;
        margin-bottom: 1.2rem;
        line-height: 1.4;
        border-left: 2px solid #ff6b6b;
    }

    /* SIMPLE BUY BUTTON */
    .btn-buy-simple {
        display: block;
        width: 100%;
        text-align: center;
        background: #111;
        color: #fff;
        padding: 0.8rem;
        border-radius: 6px;
        font-size: 0.95rem;
        font-weight: 600;
        text-decoration: none;
        transition: background 0.2s ease;
        margin-top: auto; /* Aligns button to bottom of card */
    }

    .btn-buy-simple:hover {
        background: #333;
    }

    /* MINIMAL SHIPPING TEXT */
    .shipping-text {
        font-size: 0.75rem;
        color: #888;
        text-align: center;
        margin-top: 0.8rem;
        line-height: 1.3;
    }

    /* MOBILE RESPONSIVE LAYOUT */
    @media (max-width: 600px) {
        .ecommerce-grid {
            grid-template-columns: 1fr; /* Switch to 1 column on small screens */
        }
        
        .store-catalog-container {
            max-width: 400px; /* Constrain mobile card size so it doesn't get excessively large */
        }
    }
</style>

<!-- CLIENT-SIDE JAVASCRIPT -->
<!-- Animated counter logic for the philanthropy text -->
<script>
    document.addEventListener("DOMContentLoaded", () => {
        const counters = document.querySelectorAll('.animate-counter');
        
        const observer = new IntersectionObserver((entries) => {
            entries.forEach(entry => {
                if (entry.isIntersecting) {
                    const counter = entry.target as HTMLElement;
                    const target = +counter.getAttribute('data-target')!;
                    let count = 0;
                    
                    const updateCount = () => {
                        const inc = target / 20; 
                        if (count < target) {
                            count += inc;
                            counter.innerText = Math.ceil(count).toString();
                            setTimeout(updateCount, 30);
                        } else {
                            counter.innerText = target.toString();
                        }
                    };
                    updateCount();
                    observer.unobserve(counter);
                }
            });
        }, { threshold: 0.5 });

        counters.forEach(counter => observer.observe(counter));
    });
</script>