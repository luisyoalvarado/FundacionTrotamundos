---
// src/pages/tienda.astro

// IMPORT LAYOUT
// Ensure the path to your layout file is correct based on your project structure
import Layout from '../layouts/Layout.astro';

// SEO & METADATA CONFIGURATION
// Define specific metadata for the store page to ensure good social sharing
const pageTitle = "Tienda Oficial | Fundación Trotamundos";
const pageDescription = "Adquiere el libro 'Lo que guardo en mi maleta' y apoya la misión de El Trotamundos. Cada compra transforma vidas.";
const siteUrl = "https://fundaciontrotamundos.org/tienda";
const ogImage = "https://fundaciontrotamundos.org/assets/img/libro-lo-que-guardo-en-mi-maleta-el-trotamundos.jpg";

// GEO SCHEMA MARKUP (JSON-LD)
// Product & Offer data injected for AI search engines and rich snippets
const schemaMarkup = JSON.stringify({
  "@context": "https://schema.org",
  "@type": "Product",
  "name": "Libro: Lo que guardo en mi maleta",
  "image": ogImage,
  "description": pageDescription,
  "brand": {
    "@type": "Organization",
    "name": "Fundación Trotamundos"
  },
  "offers": {
    "@type": "Offer",
    "url": siteUrl,
    "priceCurrency": "USD",
    "price": "29.00",
    "availability": "https://schema.org/InStock",
    "seller": {
      "@type": "Organization",
      "name": "Fundación Trotamundos"
    }
  }
});
---

<Layout title={pageTitle} description={pageDescription} image={ogImage}>
    
    <!-- STRUCTURED DATA INJECTION -->
    <!-- Adds the JSON-LD schema to the head of the document for SEO/GEO -->
    <script type="application/ld+json" set:html={schemaMarkup}></script>

    <!-- PAGE HERO SECTION -->
    <!-- Retaining original classes to inherit your global style.css layout -->
    <section class="internal-hero tienda-bg">
        <h1>Tienda <span class="highlight">Oficial</span></h1>
        <p>Conoce la historia detrás de la misión. Tu lectura construye el futuro de un niño.</p>
    </section>

    <!-- E-COMMERCE MAIN CONTAINER -->
    <main class="store-container">
        
        <!-- PRODUCT HERO BOX -->
        <!-- Modern, interactive product card with grid layout -->
        <article class="product-card">
            
            <!-- PRODUCT VISUAL / IMAGE GALLERY -->
            <div class="product-visual">
                <div class="image-wrapper">
                    <img 
                        src="/assets/img/libro-lo-que-guardo-en-mi-maleta-el-trotamundos.jpg" 
                        alt="Portada del libro: Lo que guardo en mi maleta" 
                        loading="lazy"
                    />
                </div>
            </div>

            <!-- PRODUCT INFORMATION & CHECKOUT -->
            <div class="product-info">
                <span class="product-badge">Libro Oficial</span>
                <h2 class="product-title">Lo que guardo en mi maleta</h2>
                
                <div class="product-description">
                    <p>Una colección de anécdotas e imágenes que recoge experiencias transformadoras vividas por El Trotamundos en su gesta humanitaria y de servicio por veintiocho países alrededor del mundo.</p>
                    <p>Al leerlo, sentirás que eres parte de cada instante vivido por este personaje en su misión de transformar el mundo un niño a la vez.</p>
                </div>

                <!-- VALUE PROPOSITION FEATURES -->
                <ul class="product-features">
                    <li>
                        <i class="fas fa-check-circle feature-icon blue-icon"></i> 
                        <span>Memorias de 28 países recorridos.</span>
                    </li>
                    <li>
                        <i class="fas fa-check-circle feature-icon blue-icon"></i> 
                        <span>Fotografías exclusivas de la fundación.</span>
                    </li>
                    <li>
                        <i class="fas fa-heart feature-icon red-icon"></i> 
                        <!-- ANIMATED NUMBER COUNTER INJECTION -->
                        <span><strong><span class="animate-counter" data-target="100">0</span>% de las ganancias</strong> apoyan nuestros proyectos.</span>
                    </li>
                </ul>

                <!-- CALL TO ACTION & CHECKOUT AREA -->
                <div class="checkout-section">
                    <a href="https://buy.stripe.com/5kQaEXd3Mc1i1DO64t2kw00" class="btn-checkout">
                        <span class="btn-text">
                            <i class="fas fa-shopping-basket"></i> 
                            Comprar Libro
                        </span>
                        <span class="btn-price">$29.00</span>
                    </a>
                    
                    <!-- UPDATED SHIPPING NOTE FROM HTML -->
                    <p class="shipping-note">
                        <i class="fas fa-truck-fast"></i> 
                        Tarifa fija de $5.00 para envíos estándar a 🇵🇷 y 🇺🇸
                    </p>
                </div>
            </div>
        </article>
    </main>
</Layout>

<!-- SCOPED COMPONENT STYLES -->
<!-- These styles only apply to this specific Astro page, keeping global CSS clean -->
<style>
    /* MAIN WRAPPER SETTINGS */
    .store-container {
        max-width: 1050px;
        margin: 5rem auto;
        padding: 0 1.5rem;
    }

    /* MODERN PRODUCT CARD (HERO BOX) */
    .product-card {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 4rem;
        align-items: center;
        background: #ffffff;
        padding: 3rem;
        border-radius: 16px;
        box-shadow: 0 10px 40px rgba(0, 0, 0, 0.04);
        border: 1px solid rgba(0, 0, 0, 0.05);
        transition: transform 0.3s ease, box-shadow 0.3s ease;
    }

    /* HOVER ACTION FOR THE ENTIRE CARD */
    .product-card:hover {
        transform: translateY(-5px);
        box-shadow: 0 20px 50px rgba(0, 0, 0, 0.08);
    }

    /* PRODUCT IMAGE STYLING */
    .product-visual {
        display: flex;
        justify-content: center;
        align-items: center;
    }

    .image-wrapper {
        width: 100%;
        max-width: 420px;
        position: relative;
        overflow: hidden;
        border-radius: 12px;
        box-shadow: 0 15px 35px rgba(0, 0, 0, 0.12);
    }

    .image-wrapper img {
        width: 100%;
        height: auto;
        display: block;
        transition: transform 0.5s ease;
    }

    /* HOVER ACTION FOR THE IMAGE (SUBTLE ZOOM) */
    .image-wrapper:hover img {
        transform: scale(1.05);
    }

    /* TYPOGRAPHY & LAYOUT FOR PRODUCT INFO */
    .product-info {
        display: flex;
        flex-direction: column;
    }

    .product-badge {
        display: inline-block;
        font-size: 0.85rem;
        text-transform: uppercase;
        letter-spacing: 1.5px;
        font-weight: 700;
        color: #4facfe;
        margin-bottom: 0.8rem;
    }

    .product-title {
        font-size: 2.4rem;
        font-weight: 800;
        color: #1a1a1a;
        margin-bottom: 1.2rem;
        line-height: 1.2;
    }

    .product-description p {
        color: #555;
        line-height: 1.7;
        font-size: 1.05rem;
        margin-bottom: 1rem;
    }

    /* FEATURES LIST STYLING */
    .product-features {
        list-style: none;
        padding: 1.5rem;
        margin: 1.5rem 0;
        background: #f8f9fa;
        border-radius: 12px;
        border: 1px solid #eaeaea;
    }

    .product-features li {
        margin-bottom: 1rem;
        display: flex;
        align-items: center;
        gap: 15px;
        font-size: 1.05rem;
        color: #333;
    }

    .product-features li:last-child {
        margin-bottom: 0;
    }

    .feature-icon {
        font-size: 1.2rem;
        min-width: 24px;
        text-align: center;
    }

    .blue-icon { color: #4facfe; }
    .red-icon { color: #ff6b6b; }

    /* CHECKOUT BUTTON & CONTAINER */
    .checkout-section {
        margin-top: 1rem;
    }

    .btn-checkout {
        display: flex;
        align-items: center;
        justify-content: space-between;
        padding: 1.2rem 2rem;
        background: #1a1a1a;
        color: #ffffff;
        border-radius: 10px;
        text-decoration: none;
        font-size: 1.15rem;
        font-weight: 600;
        transition: background 0.3s ease, transform 0.2s ease, box-shadow 0.3s ease;
    }

    /* HOVER ACTION FOR THE BUY BUTTON */
    .btn-checkout:hover {
        background: #333333;
        transform: translateY(-2px);
        box-shadow: 0 10px 20px rgba(0,0,0,0.15);
        color: #ffffff; /* Ensures link color stays white in Astro */
    }

    .btn-price {
        border-left: 1px solid rgba(255, 255, 255, 0.3);
        padding-left: 20px;
        font-weight: 800;
        font-size: 1.25rem;
    }

    .shipping-note {
        margin-top: 1.2rem;
        color: #666;
        font-size: 0.95rem;
        text-align: center;
        display: flex;
        align-items: center;
        justify-content: center;
        gap: 8px;
        font-weight: 500;
    }

    /* RESPONSIVE DESIGN RULES */
    @media (max-width: 900px) {
        .product-card {
            grid-template-columns: 1fr;
            gap: 2.5rem;
            padding: 2rem;
        }

        .product-title {
            font-size: 2rem;
        }

        .btn-checkout {
            flex-direction: column;
            gap: 15px;
            text-align: center;
        }

        .btn-price {
            border-left: none;
            border-top: 1px solid rgba(255, 255, 255, 0.2);
            padding-left: 0;
            padding-top: 15px;
            width: 100%;
        }
    }
</style>

<!-- CLIENT-SIDE JAVASCRIPT -->
<!-- Handles dynamic interactions that run on the user's browser -->
<script>
    // Intersection Observer for animated number counters
    // Triggers the count-up animation when the element scrolls into view
    document.addEventListener("DOMContentLoaded", () => {
        const counters = document.querySelectorAll('.animate-counter');
        
        const observer = new IntersectionObserver((entries) => {
            entries.forEach(entry => {
                if (entry.isIntersecting) {
                    const counter = entry.target as HTMLElement;
                    const target = +counter.getAttribute('data-target')!;
                    let count = 0;
                    
                    // Recursive function to animate the number smoothly
                    const updateCount = () => {
                        const inc = target / 20; // Controls the speed of the counter
                        if (count < target) {
                            count += inc;
                            counter.innerText = Math.ceil(count).toString();
                            setTimeout(updateCount, 30);
                        } else {
                            counter.innerText = target.toString();
                        }
                    };
                    updateCount();
                    
                    // Stop observing once the animation completes
                    observer.unobserve(counter);
                }
            });
        }, { threshold: 0.5 }); // Triggers when 50% of the element is visible

        counters.forEach(counter => observer.observe(counter));
    });
</script>