---
// src/components/Footer.astro
// [English Comment: Get the current year dynamically for the copyright notice]
const currentYear = new Date().getFullYear();
---

<!-- [English Comment: Main footer container] -->
<footer class="site-footer">
    <div class="footer-grid">
        <!-- [English Comment: Left column containing foundation details and social media links] -->
        <div class="footer-col-left">
            <div>
                <p style="font-size: 1.2rem; font-weight: 700; margin-bottom: 5px;">Fundación Trotamundos</p>
                <p style="opacity: 0.8; font-size: 0.95rem;">Transformando el mundo un niño a la vez.</p>
                <p style="opacity: 0.8; font-size: 0.95rem;"><i class="fas fa-map-marker-alt" style="margin-right: 5px;"></i> San Juan, Puerto Rico</p>
            </div>
            <div class="footer-socials-new">
                <a href="https://facebook.com/ElTrotamun2" target="_blank" class="share-btn fb" aria-label="Facebook"><i class="fab fa-facebook-f"></i></a>
                <a href="https://instagram.com/eltrotamundos" target="_blank" class="share-btn ig" aria-label="Instagram"><i class="fab fa-instagram"></i></a>
                <a href="https://youtube.com/eltrotamun2" target="_blank" class="share-btn yt" aria-label="YouTube"><i class="fab fa-youtube"></i></a>
            </div>
        </div>

        <!-- [English Comment: Right column containing commercial booking information] -->
        <div class="footer-col-right">
            <div class="footer-commercial-notice-new">
                <p style="margin-bottom: 5px;"><strong>¿Buscas los shows de El Trotamundos?</strong></p>
                <p style="font-size: 0.9rem; margin-bottom: 0;">Para contrataciones de espectáculos y animaciones, visita nuestra página oficial de talento: <br>
                <a href="https://www.eltrotamundos.com" target="_blank">www.eltrotamundos.com</a></p>
            </div>
        </div>
    </div>

    <!-- [English Comment: Visual separator line] -->
    <hr class="footer-divider">
    
    <!-- [English Comment: Footer credits including copyright and the professional portfolio backlink] -->
    <div class="footer-credits" style="text-align: center;">
        <p style="margin-bottom: 5px;">&copy; {currentYear} Fundación Trotamundos. Todos los derechos reservados.</p>
        <p style="font-size: 0.85rem; opacity: 0.8; margin: 0;">
            Estrategia Digital por <a href="https://luisjoann.com" target="_blank" rel="noopener noreferrer" style="color: inherit; font-weight: 600; text-decoration: none;">LuisJoann</a>
        </p>
    </div>
</footer>